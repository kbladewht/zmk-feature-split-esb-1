menuconfig ZMK_SPLIT_ESB
    bool "ZMK ESB split transport"
    depends on ZMK_SPLIT
    select ESB
    help
      Enhanced ShockBurst (2.4 GHz) split transport for one or more peripherals and a
      single central. One ESB packet carries one complete split message.
      ESB hardware ACK, retransmit and CRC provide reliability.

if ZMK_SPLIT_ESB

config ZMK_SPLIT_ESB_MAX_PAYLOAD
    int "Max on-air payload bytes"
    default 48
    help
      Must be >= the largest split message struct. A build assert checks this.

config ZMK_SPLIT_ESB_RX_QUEUE_SIZE
    int "Received-packet ring depth (power of 2)"
    default 16
    help
      Lock-free SPSC ring between the radio ISR and the dispatch thread. Must be
      a power of 2. Deep enough to ride out dispatch stalls at the RX rate.

config ZMK_SPLIT_ESB_RX_THREAD_STACK_SIZE
    int "RX dispatch thread stack size"
    default 1536
    help
      Dispatch thread decodes packets and forwards input events to the input
      subsystem. Behavior-bound traffic is handed to the system workqueue, so
      ZMK keymap and behavior code never runs on this stack.

config ZMK_SPLIT_ESB_RX_THREAD_PRIORITY
    int "RX dispatch thread priority"
    default 2

config ZMK_SPLIT_ESB_EVENT_QUEUE_SIZE
    int "Central: behavior-bound event queue depth"
    default 16
    help
      Key, sensor and battery events queue here for the system workqueue,
      where ZMK behavior state lives. Input events bypass this queue.

config ZMK_SPLIT_ESB_COMMAND_QUEUE_SIZE
    int "Peripheral: inbound command queue depth"
    default 8
    help
      Central commands (behavior invocations, HID indicators) queue here for
      the system workqueue.

config ZMK_SPLIT_ESB_REPLY_QUEUE_SIZE
    int "Central: pending reverse-channel command depth"
    default 8

config ZMK_SPLIT_ESB_PRIORITY
    int "Split transport registration priority"
    default 50

config ESB_MAX_PAYLOAD_LENGTH
    default ZMK_SPLIT_ESB_MAX_PAYLOAD

module = ZMK_SPLIT_ESB
module-str = ZMK ESB split transport
source "subsys/logging/Kconfig.template.log_config"

endif # ZMK_SPLIT_ESB
